{
  "name": "@content-hub/engine",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./image/*": {
      "types": "./dist/image/*.d.ts",
      "import": "./dist/image/*.js"
    }
  },
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "dev": "tsc --watch",
    "copy-assets": "rm -rf dist/preview/themes && cp -r src/preview/themes dist/preview/themes",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@content-hub/adapter": "workspace:*",
    "@content-hub/config": "workspace:*",
    "@content-hub/core": "workspace:*",
    "@content-hub/database": "workspace:*",
    "@content-hub/linker": "workspace:*",
    "@content-hub/transformer": "workspace:*",
    "@hono/node-server": "^1.8.2",
    "@prisma/client": "^5.8.0",
    "@types/marked": "^6.0.0",
    "axios": "^1.14.0",
    "clipboardy": "^4.0.0",
    "dotenv": "^16.3.1",
    "form-data": "^4.0.5",
    "highlight.js": "^11.11.1",
    "hono": "^4.0.0",
    "marked": "^17.0.5",
    "marked-highlight": "^2.2.3",
    "open": "^10.1.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/form-data": "^2.5.2"
  }
}
