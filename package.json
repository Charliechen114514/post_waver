{
  "name": "content-hub",
  "version": "0.1.0",
  "private": true,
  "description": "本地优先的内容管理系统",
  "scripts": {
    "dev": "pnpm --filter web-ui dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "typecheck": "pnpm -r typecheck",
    "sync:blog": "bash scripts/update-blog.sh"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "eslint": "^8.56.0",
    "hexo": "^8.1.1",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "lint-staged": {
    "*.md": [
      "markdownlint-cli2 --fix",
      "remark --frail"
    ],
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
