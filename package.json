{
  "name": "content-hub",
  "version": "0.1.0",
  "private": true,
  "description": "本地优先的内容管理系统",
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "dev:web": "pnpm --filter web-ui dev",
    "dev:api": "tsx scripts/api-server.ts",
    "build": "pnpm -r --workspace-concurrency=1 run build",
    "lint": "pnpm lint:md && pnpm lint:ts",
    "lint:md": "markdownlint-cli2 '**/*.md'",
    "lint:md:fix": "markdownlint-cli2 --fix '**/*.md'",
    "lint:ts": "pnpm -r lint",
    "lint:fix": "pnpm lint:md:fix && pnpm -r lint:fix",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:units": "bash test/scripts/test-units.sh",
    "test:integration": "bash test/scripts/test-integration.sh",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "typecheck": "pnpm -r typecheck",
    "scan": "npx tsx scripts/scan.ts --dir content/posts",
    "scan:table": "npx tsx scripts/scan.ts --dir content/posts --output table",
    "scan:drafts": "npx tsx scripts/scan.ts --dir content/posts --include-drafts --output table",
    "index:rebuild": "npx tsx scripts/scan.ts --dir content/posts --include-drafts",
    "sync:hexo": "npx tsx scripts/sync-to-hexo.ts",
    "sync:blog": "bash scripts/update-blog.sh",
    "migrate-images": "tsx scripts/migrate-images.ts",
    "python:install": "cd packages/linker && pip3 install -r requirements.txt",
    "test:migrate-images": "bash test/scripts/test-migrate-images.sh",
    "transform:html": "tsx scripts/transform.ts html",
    "transform:wechat": "tsx scripts/transform.ts wechat",
    "transform:juejin": "tsx scripts/transform.ts juejin",
    "preview:wechat": "tsx scripts/preview.ts wechat",
    "preview:juejin": "tsx scripts/preview.ts juejin",
    "preview:html": "tsx scripts/preview.ts html",
    "platform:id:update": "tsx scripts/update-platform-id.ts update",
    "platform:id:remove": "tsx scripts/update-platform-id.ts remove",
    "platform:id:status": "tsx scripts/update-platform-id.ts status",
    "platform:id:import": "tsx scripts/update-platform-id.ts import",
    "platform:id:list": "tsx scripts/update-platform-id.ts list",
    "test:workflow:full": "bash scripts/test-workflow-local.sh",
    "test:build": "pnpm build && pnpm --filter @content-hub/web-ui build",
    "test:workflow:act": "act -j deploy -n",
    "preview:prod": "pnpm --filter @content-hub/web-ui preview --host 0.0.0.0 --port 4173",
    "db:init": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "post:status": "tsx scripts/db-status.ts",
    "post:update-status": "tsx scripts/db-update-status.ts",
    "test:image:create-sample": "tsx scripts/test-image-create-sample.ts",
    "test:image:juejin": "tsx scripts/test-image-juejin.ts",
    "test:image:wechat": "tsx scripts/test-image-wechat.ts",
    "publish:generate": "tsx scripts/publish-generate.ts",
    "publish:set-url": "tsx scripts/publish-set-url.ts",
    "publish:full": "tsx scripts/publish-full.ts",
    "publish:history": "tsx scripts/publish-history.ts",
    "publish:cleanup": "tsx scripts/publish-cleanup.ts",
    "config:set": "tsx scripts/config-set.ts",
    "config:list": "tsx scripts/config-list.ts",
    "workflow:scan": "npx tsx scripts/workflow-scan.ts",
    "workflow:process": "npx tsx scripts/workflow-process.ts",
    "workflow:process-all": "npx tsx scripts/workflow-process-all.ts",
    "workflow:status": "npx tsx scripts/workflow-status.ts",
    "workflow:rollback": "npx tsx scripts/workflow-rollback.ts",
    "workflow:history": "npx tsx scripts/workflow-history.ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "commander": "^14.0.3",
    "eslint": "^8.56.0",
    "hexo": "^8.1.1",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "markdownlint-cli2": "^0.22.0",
    "open": "^10.0.0",
    "prettier": "^3.2.0",
    "remark-cli": "^12.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-lint": "^10.0.1",
    "remark-lint-list-item-indent": "^4.0.1",
    "remark-lint-list-item-spacing": "^5.0.1",
    "remark-lint-no-missing-blank-lines": "^4.0.1",
    "remark-preset-lint-recommended": "^7.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "lint-staged": {
    "*.md": [
      "markdownlint-cli2 --fix",
      "remark --frail"
    ],
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
